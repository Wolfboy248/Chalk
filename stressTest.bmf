    task_16 {
      "order" "2"
      "title" "Trigonometry"      

      formulas {        

        formula_17 {
          "explanation" ""
          "isAnswer" "0"
          "latex" "\angle A=70\degree"
          "order" "0"
          "result" ""
        }

        formula_18 {
          "explanation" ""
          "isAnswer" "0"
          "latex" "a=7\ cm"
          "order" "1"
          "result" ""
        }

        formula_19 {
          "explanation" ""
          "isAnswer" "0"
          "latex" "b=5\ cm"
          "order" "2"
          "result" ""
        }

        formula_20 {
          "explanation" ""
          "isAnswer" "1"
          "latex" "\angle B=\arcsin\left(\frac{\sin\left(\angle A\right)}{a}\cdot b\right)"
          "order" "3"
          "result" "42,\!16\degree"
        }

        formula_21 {
          "explanation" "To be fixed: should not have to write angle B degree."
          "isAnswer" "1"
          "latex" "\angle C=180\degree-\angle A-\angle B\degree"
          "order" "4"
          "result" "109,\!3\degree"
        }

        formula_22 {
          "explanation" ""
          "isAnswer" "1"
          "latex" "c=\frac{a}{\sin\left(\angle A\right)}\cdot\sin\left(\angle C\right)"
          "order" "5"
          "result" "7,\!032\, cm"
        }
      }

