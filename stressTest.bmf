    task_0 {
      "order" "0"
      "title" "Vectors"      

      formulas {        

        formula_1 {
          "explanation" "Vectors are written by writing 'vec' and then the name of the vector. Use angle brackets to define them."
          "isAnswer" "0"
          "latex" "\vec{v}=\left[2;3\right]"
          "order" "0"
          "result" ""
        }

        formula_2 {
          "explanation" ""
          "isAnswer" "0"
          "latex" "\vec{AB}=\left[2;3\right]"
          "order" "1"
          "result" ""
        }

        formula_3 {
          "explanation" ""
          "isAnswer" "0"
          "latex" "\vec{v}+\vec{AB}"
          "order" "2"
          "result" "[4; 6]"
        }

        formula_4 {
          "explanation" ""
          "isAnswer" "0"
          "latex" "\vec{v}\cdot\vec{AB}"
          "order" "3"
          "result" "13"
        }

        formula_5 {
          "explanation" "'Any' dimensional vectors are supported."
          "isAnswer" "0"
          "latex" "\vec{v_1}=\left[2;3;4\right]"
          "order" "4"
          "result" ""
        }

        formula_6 {
          "explanation" ""
          "isAnswer" "0"
          "latex" "\vec{v_2}=\left[4;5;6\right]"
          "order" "5"
          "result" ""
        }

        formula_7 {
          "explanation" ""
          "isAnswer" "0"
          "latex" "\vec{v_1}\cdot\vec{v_2}"
          "order" "6"
          "result" "47"
        }
      }

